 <!-- macOS: add iOS + MacCatalyst -->
  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('osx'))">
    <TargetFrameworks>
      net9.0-android;
      net9.0-ios;
      net9.0-maccatalyst
    </TargetFrameworks>
  </PropertyGroup>

  <!-- Windows: add Windows target -->
  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('windows'))">
    <TargetFrameworks>
      $(TargetFrameworks);
      net9.0-windows9.0.19041.0
    </TargetFrameworks>
  </PropertyGroup>