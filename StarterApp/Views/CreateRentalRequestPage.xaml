<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.CreateRentalRequestPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <Label Text="{Binding ItemId, StringFormat='Item ID: {0}'}"
                   FontSize="14" />

            <!-- AI-assisted: display the query-supplied rate used for the client-side estimate. -->
            <Label Text="{Binding DailyRate, StringFormat='Daily rate: £{0:F2}'}"
                   FontSize="14" />

            <Label Text="Start Date"
                   FontAttributes="Bold" />

            <DatePicker Date="{Binding StartDate}" />

            <Label Text="End Date"
                   FontAttributes="Bold" />

            <DatePicker Date="{Binding EndDate}" />

            <!-- AI-assisted: show the calculated rental duration and estimated total without changing submission. -->
            <Label Text="{Binding RentalDays, StringFormat='Rental days: {0}'}"
                   FontSize="14" />

            <Label Text="{Binding EstimatedTotal, StringFormat='Estimated total: £{0:F2}'}"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Button Text="Submit Rental Request"
                    Command="{Binding SubmitRequestCommand}" />

            <Button Text="Cancel"
                    Command="{Binding CancelCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
