<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.ItemDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="{Binding Item.Title}"
                   FontSize="26"
                   FontAttributes="Bold" />

            <Label Text="{Binding Item.Description}"
                   FontSize="16" />

            <Label Text="{Binding Item.Category, StringFormat='Category: {0}'}"
                   FontSize="14" />

            <Label Text="{Binding Item.OwnerName, StringFormat='Owner: {0}'}"
                   FontSize="14" />

            <Label Text="{Binding Item.DailyRate, StringFormat='£{0:F2} / day'}"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Label Text="{Binding Item.IsAvailable, StringFormat='Available: {0}'}"
                   FontSize="14" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>