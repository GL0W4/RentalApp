<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.CreateReviewPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <Label Text="Leave Review"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="{Binding RentalId, StringFormat='Rental ID: {0}'}"
                   FontSize="14" />

            <Label Text="Rating" />

            <Picker SelectedIndex="{Binding Rating}">
                <Picker.Items>
                    <x:String>0</x:String>
                    <x:String>1</x:String>
                    <x:String>2</x:String>
                    <x:String>3</x:String>
                    <x:String>4</x:String>
                    <x:String>5</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Comment" />

            <Editor Text="{Binding Comment}"
                    Placeholder="Optional comment"
                    AutoSize="TextChanges"
                    HeightRequest="120" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />

            <Button Text="Submit Review"
                    TextColor="White"
                    Command="{Binding SubmitReviewCommand}" />

            <Button Text="Cancel"
                    TextColor="White"
                    Command="{Binding CancelCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>