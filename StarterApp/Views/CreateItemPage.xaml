<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.CreateItemPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <Entry Placeholder="Title"
                   Text="{Binding TitleText}" />

            <Editor Placeholder="Description"
                    Text="{Binding Description}"
                    AutoSize="TextChanges"
                    HeightRequest="120" />

            <Picker Title="Select Category"
                    ItemsSource="{Binding Categories}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedCategory}" />

            <Entry Placeholder="Daily Rate"
                   Text="{Binding DailyRateText}"
                   Keyboard="Numeric" />

            <Entry Placeholder="Latitude"
                   Text="{Binding LatitudeText}"
                   Keyboard="Numeric" />

            <Entry Placeholder="Longitude"
                   Text="{Binding LongitudeText}"
                   Keyboard="Numeric" />

            <Button Text="Save Item"
                    Command="{Binding SaveItemCommand}" />

            <Button Text="Cancel"
                    Command="{Binding CancelCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>