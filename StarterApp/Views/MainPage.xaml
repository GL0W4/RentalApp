<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Profile"
                     Command="{Binding NavigateToProfileCommand}"
                     IconImageSource="user.png" />
        <ToolbarItem Text="Settings"
                     Command="{Binding NavigateToSettingsCommand}"
                     IconImageSource="settings.png" />
        <ToolbarItem Text="Logout"
                     Command="{Binding LogoutCommand}"
                     IconImageSource="logout.png" />
    </ContentPage.ToolbarItems>

    <RefreshView Command="{Binding RefreshDataCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- Welcome Section -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Padding="20"
                        HeightRequest="120">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                        <Label Text="{Binding WelcomeMessage}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center" />

                        <Label Text="Rental marketplace dashboard"
                               FontSize="14"
                               TextColor="White"
                               Opacity="0.85"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Error Display -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                        Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                        StrokeThickness="1"
                        Padding="15"
                        IsVisible="{Binding HasError}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                               FontSize="14"
                               VerticalOptions="Center"
                               HorizontalOptions="FillAndExpand" />

                        <Button Text="×"
                                Command="{Binding ClearErrorCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                                FontSize="18"
                                Padding="5"
                                WidthRequest="30"
                                HeightRequest="30" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Quick Actions -->
                <Label Text="Quick Actions"
                       FontSize="20"
                       FontAttributes="Bold"
                       Margin="0,10,0,0" />

                <!-- Browse Items Card -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        StrokeThickness="1"
                        Padding="20"
                        HeightRequest="90">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToItemsListCommand}" />
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="📦"
                               FontSize="26"
                               VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Column="1"
                                             Margin="15,0,0,0"
                                             VerticalOptions="Center"
                                             Spacing="3">
                            <Label Text="Browse Items"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            <Label Text="View available listings and item details"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        </VerticalStackLayout>

                        <Label Grid.Column="2"
                               Text=">"
                               FontSize="18"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}" />
                    </Grid>
                </Border>

                <!-- Rental Requests Card -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        StrokeThickness="1"
                        Padding="20"
                        HeightRequest="90">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToRentalRequestsCommand}" />
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="📄"
                               FontSize="26"
                               VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Column="1"
                                             Margin="15,0,0,0"
                                             VerticalOptions="Center"
                                             Spacing="3">
                            <Label Text="Rental Requests"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            <Label Text="View incoming and outgoing rental requests"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        </VerticalStackLayout>

                        <Label Grid.Column="2"
                               Text=">"
                               FontSize="18"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}" />
                    </Grid>
                </Border>

                <!-- Profile Card -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        StrokeThickness="1"
                        Padding="20"
                        HeightRequest="90">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToProfileCommand}" />
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="👤"
                               FontSize="26"
                               VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Column="1"
                                             Margin="15,0,0,0"
                                             VerticalOptions="Center"
                                             Spacing="3">
                            <Label Text="Profile"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            <Label Text="View account information"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        </VerticalStackLayout>

                        <Label Grid.Column="2"
                               Text=">"
                               FontSize="18"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}" />
                    </Grid>
                </Border>

                <!-- Settings Card -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        StrokeThickness="1"
                        Padding="20"
                        HeightRequest="90">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToSettingsCommand}" />
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="⚙️"
                               FontSize="26"
                               VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Column="1"
                                             Margin="15,0,0,0"
                                             VerticalOptions="Center"
                                             Spacing="3">
                            <Label Text="Settings"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            <Label Text="Open app preferences"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        </VerticalStackLayout>

                        <Label Grid.Column="2"
                               Text=">"
                               FontSize="18"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
